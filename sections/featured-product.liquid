{%- assign product = all_products[section.settings.product] -%}
{%- if product == empty -%}
  {%- assign product = all_products.first -%}
{%- endif -%}

<style>
.product-gallery__main { position: relative; }
.gallery-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 30px; height: 30px; border-radius: 50%;
  background: rgba(255,255,255,0.55); border: 1px solid rgba(0,0,0,0.06);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 5; color: var(--text-dark);
  font-size: 20px; line-height: 1; padding: 0;
  opacity: 0.4; transition: opacity .2s; backdrop-filter: blur(4px);
}
.gallery-arrow:hover { opacity: 0.85; }
.gallery-arrow--prev { left: 10px; }
.gallery-arrow--next { right: 10px; }
</style>

{%- assign first_variant = product.first_available_variant -%}

<section class="featured-product" id="product">
  <div class="featured-product__grid">

    <!-- LEFT: GALLERY + PURCHASE ACTIONS -->
    <div class="product-gallery">
      <div class="product-gallery__main" id="gallery-main">
        {%- if product.featured_image -%}
          <img
            id="gallery-main-img"
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | default: product.title }}"
            width="800" height="800"
            loading="eager"
          >
        {%- else -%}
          <div style="font-size:80px;">💜</div>
        {%- endif -%}
        {%- if product.images.size > 1 -%}
          <button class="gallery-arrow gallery-arrow--prev" aria-label="Previous image">&#8249;</button>
          <button class="gallery-arrow gallery-arrow--next" aria-label="Next image">&#8250;</button>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
      <div class="product-gallery__thumbs" id="gallery-thumbs">
        {%- for image in product.images limit: 5 -%}
        <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}">
          <img
            src="{{ image | image_url: width: 150 }}"
            alt="{{ image.alt | default: product.title }}"
            width="72" height="72"
            loading="lazy"
          >
        </div>
        {%- endfor -%}
      </div>
      {%- endif -%}

      <script>
      (function(){
        var images = [{% for image in product.images limit: 5 %}"{{ image | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}{% endfor %}];
        if(images.length < 2) return;
        var current = 0;
        var mainImg = document.getElementById('gallery-main-img');
        var thumbs = document.querySelectorAll('#gallery-thumbs .product-gallery__thumb');
        function goTo(idx){
          current = (idx + images.length) % images.length;
          mainImg.src = images[current];
          thumbs.forEach(function(t,i){ t.classList.toggle('active', i === current); });
        }
        document.querySelector('.gallery-arrow--prev').addEventListener('click', function(){ goTo(current - 1); });
        document.querySelector('.gallery-arrow--next').addEventListener('click', function(){ goTo(current + 1); });
        thumbs.forEach(function(t,i){ t.addEventListener('click', function(){ goTo(i); }); });
      })();
      </script>

      <!-- Purchase Type Toggle -->
      <div class="purchase-toggle" role="group" aria-label="Purchase type" style="margin-top:24px;">
        <button type="button" class="purchase-toggle__btn active" data-type="one-time">
          <span class="toggle-label">One-time Purchase</span>
          <span class="toggle-sub">{{ first_variant.price | money }}</span>
        </button>
        <button type="button" class="purchase-toggle__btn" data-type="subscribe">
          <span class="toggle-label">Subscribe &amp; Save <span class="save-badge">Save R50</span></span>
          <span class="toggle-sub">From R399/month</span>
        </button>
      </div>

      <!-- Subscription frequency -->
      <div class="subscribe-options" id="subscribe-options-hp">
        <label>Delivery frequency</label>
        <select id="subscribe-freq-hp">
          <option value="1">Every month — R399</option>
          <option value="2">Every 2 months — R399</option>
        </select>
        <div class="subscribe-perk">✅ Cancel or pause anytime · No lock-in</div>
      </div>

      <!-- Price -->
      <div class="product-info__price" style="margin-bottom:24px;">
        {%- if product.compare_at_price > product.price -%}
          <span class="price" id="product-price">{{ product.price | money }}</span>
          <s style="font-size:20px;color:var(--text-light);margin-left:12px;">{{ product.compare_at_price | money }}</s>
        {%- else -%}
          <span class="price" id="product-price">{{ product.price | money }}</span>
        {%- endif -%}
        <p class="price-note">30 gummies · 30-day supply</p>
      </div>

      <!-- Qty + ATC -->
      <form action="/cart/add" method="post" enctype="multipart/form-data" id="product-form-hp">
        <input type="hidden" name="id" value="{{ first_variant.id }}">

        <div class="quantity-selector">
          <button type="button" class="qty-btn qty-minus" aria-label="Decrease quantity">−</button>
          <input class="qty-input" type="number" name="quantity" value="1" min="1" max="10" aria-label="Quantity">
          <button type="button" class="qty-btn qty-plus" aria-label="Increase quantity">+</button>
        </div>

        <button
          type="submit"
          class="add-to-cart"
          data-variant-id="{{ first_variant.id }}"
          {% unless first_variant.available %}disabled{% endunless %}
        >
          {%- if first_variant.available -%}
            Add to Cart →
          {%- else -%}
            Sold Out
          {%- endif -%}
        </button>
      </form>

      <div class="product-info__trust" style="margin-top:20px;">
        <span class="trust-badge">🚚 Free delivery over R500</span>
        <span class="trust-badge">🔄 Easy returns</span>
        <span class="trust-badge">🔒 Secure checkout</span>
      </div>
    </div>

    <!-- RIGHT: PRODUCT INFO -->
    <div class="product-info" style="padding-top:48px;">
      <div class="product-info__flavour-badge">🍊 Juicy Citrus · High Performance</div>

      <h1 class="product-info__name">{{ product.title | default: 'Creatine Gummies' }}</h1>
      <p class="product-info__tagline">Creatine Monohydrate + Vitamin B6 + Electrolytes</p>

      <div class="product-info__stars">
        ★★★★★ <span>4.9 · 100+ happy athletes</span>
      </div>

      <p class="product-info__desc">
        {{ product.description | default: 'The most researched supplement in sports nutrition — now in a delicious gummy. No powder, no mixing, no chalky taste. Just pure creatine monohydrate that actually tastes good.' | strip_html | truncate: 200 }}
      </p>

      <div class="ingredient-pills">
        <span class="pill">💪 Creatine Monohydrate</span>
        <span class="pill">⚡ Vitamin B6</span>
        <span class="pill">🍊 Citrus Flavour</span>
      </div>

      <ul class="product-info__benefits">
        <li><span class="benefit-dot"></span> Build lean muscle — faster than any powder</li>
        <li><span class="benefit-dot"></span> Increase strength &amp; power output</li>
        <li><span class="benefit-dot"></span> Improve endurance &amp; workout performance</li>
        <li><span class="benefit-dot"></span> 30 delicious juicy citrus gummies per pouch</li>
        <li><span class="benefit-dot"></span> Vegan, no chalky powder, no mixing required</li>
      </ul>

      {%- if product != empty -%}
      <a href="{{ product.url }}" style="display:block;margin-top:24px;font-size:14px;color:var(--purple-mid);font-weight:600;">
        View Full Product Details →
      </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    }
  ],
  "presets": [{ "name": "Featured Product" }]
}
{% endschema %}
