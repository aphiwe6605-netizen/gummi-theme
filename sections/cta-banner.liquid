<section class="cta-banner">
  <div class="container">
    <h2>Ready to perform?<br>We got you. 💪</h2>
    <p>Join thousands of South Africans fuelling stronger sessions with Gummi.</p>
    <div class="cta-buttons">
      <a href="/products/gummi" class="btn-primary">Shop Gummi — R{{ section.settings.price }}</a>
      <a href="#ingredients" class="btn-secondary">Learn More</a>
    </div>
    <p class="cta-note">Free delivery over R800 · 30 gummies per pouch · 🇿🇦 South Africa</p>
  </div>
</section>

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    { "type": "text", "id": "price", "label": "Price", "default": "399" }
  ],
  "presets": [{ "name": "CTA Banner" }]
}
{% endschema %}
