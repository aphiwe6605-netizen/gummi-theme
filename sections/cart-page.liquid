<section class="cart-page">
  <div class="container">

    {%- if cart.item_count > 0 -%}

    <div class="cart-page__header">
      <h1 class="cart-page__title">Your Cart</h1>
      <span class="cart-page__count">{{ cart.item_count }} {{ cart.item_count | pluralize: 'item', 'items' }}</span>
    </div>

    <div class="cart-page__grid">

      <!-- LINE ITEMS -->
      <div class="cart-items">
        {%- for item in cart.items -%}
        <div class="cart-item" data-key="{{ item.key }}">
          <a href="{{ item.url }}" class="cart-item__image-wrap">
            {%- if item.image -%}
            <img
              src="{{ item.image | image_url: width: 200 }}"
              alt="{{ item.image.alt | default: item.title }}"
              width="100" height="100"
              loading="lazy"
            >
            {%- else -%}
            <div class="cart-item__image-placeholder">🌙</div>
            {%- endif -%}
          </a>

          <div class="cart-item__details">
            <div class="cart-item__top">
              <div>
                <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                {%- unless item.variant.title == 'Default Title' -%}
                <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
              </div>
              <span class="cart-item__price">{{ item.final_line_price | money }}</span>
            </div>

            <div class="cart-item__bottom">
              <div class="cart-qty">
                <button type="button" class="cart-qty__btn" data-action="minus" data-key="{{ item.key }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease">−</button>
                <span class="cart-qty__val">{{ item.quantity }}</span>
                <button type="button" class="cart-qty__btn" data-action="plus" data-key="{{ item.key }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase">+</button>
              </div>
              <button type="button" class="cart-item__remove" data-key="{{ item.key }}" aria-label="Remove {{ item.title }}">
                Remove
              </button>
            </div>
          </div>
        </div>
        {%- endfor -%}
      </div>

      <!-- ORDER SUMMARY -->
      <div class="cart-summary">
        <h2 class="cart-summary__title">Order Summary</h2>

        <div class="cart-summary__rows">
          <div class="cart-summary__row">
            <span>Subtotal</span>
            <span id="cart-subtotal">{{ cart.total_price | money }}</span>
          </div>
          <div class="cart-summary__row cart-summary__row--shipping">
            <span>Shipping</span>
            <span>
              {%- if cart.total_price >= 80000 -%}
                <span class="cart-free-badge">FREE</span>
              {%- else -%}
                Calculated at checkout
              {%- endif -%}
            </span>
          </div>
        </div>

        {%- if cart.total_price < 80000 -%}
        <div class="cart-shipping-note">
          🚚 Add {{ 80000 | minus: cart.total_price | money }} more for free delivery
        </div>
        {%- else -%}
        <div class="cart-shipping-note cart-shipping-note--unlocked">
          ✅ You've unlocked free delivery!
        </div>
        {%- endif -%}

        <div class="cart-summary__total">
          <span>Total</span>
          <span id="cart-total">{{ cart.total_price | money }}</span>
        </div>

        <a href="/checkout" class="btn-primary cart-checkout-btn">
          Checkout →
        </a>

        <div class="cart-trust">
          <span>🔒 Secure checkout</span>
          <span>🇿🇦 Ships across SA</span>
        </div>

        <a href="/products/gummi" class="cart-continue">
          ← Continue Shopping
        </a>
      </div>

    </div>

    {%- else -%}

    <!-- EMPTY STATE -->
    <div class="cart-empty">
      <div class="cart-empty__icon">🌙</div>
      <h2 class="cart-empty__title">Your cart is empty</h2>
      <p class="cart-empty__sub">Looks like you haven't added anything yet. Good sleep is just a click away.</p>
      <a href="/products/gummi" class="btn-primary">Shop Gummi</a>
    </div>

    {%- endif -%}

  </div>
</section>

<style>
.cart-page {
  padding: 60px 24px 100px;
  min-height: 60vh;
}
.cart-page__header {
  display: flex;
  align-items: baseline;
  gap: 16px;
  margin-bottom: 48px;
}
.cart-page__title {
  font-family: var(--font-serif);
  font-size: clamp(32px, 4vw, 48px);
  color: var(--text-dark);
}
.cart-page__count {
  font-size: 14px;
  color: var(--text-light);
  font-weight: 500;
}

/* GRID */
.cart-page__grid {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 48px;
  align-items: start;
}

/* LINE ITEMS */
.cart-items {
  display: flex;
  flex-direction: column;
  gap: 0;
  border-top: 1px solid rgba(167,139,204,0.2);
}
.cart-item {
  display: flex;
  gap: 20px;
  padding: 28px 0;
  border-bottom: 1px solid rgba(167,139,204,0.2);
}
.cart-item__image-wrap {
  flex-shrink: 0;
  width: 100px;
  height: 100px;
  border-radius: 12px;
  overflow: hidden;
  background: var(--purple-pale);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-item__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.cart-item__image-placeholder {
  font-size: 40px;
}
.cart-item__details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 16px;
}
.cart-item__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
}
.cart-item__name {
  font-weight: 600;
  font-size: 16px;
  color: var(--text-dark);
  line-height: 1.3;
}
.cart-item__name:hover { color: var(--purple-mid); }
.cart-item__variant {
  font-size: 13px;
  color: var(--text-light);
  margin-top: 4px;
}
.cart-item__price {
  font-weight: 700;
  font-size: 17px;
  color: var(--purple-deep);
  white-space: nowrap;
}
.cart-item__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* QTY */
.cart-qty {
  display: flex;
  align-items: center;
  gap: 0;
  border: 1.5px solid var(--purple-light);
  border-radius: 100px;
  overflow: hidden;
}
.cart-qty__btn {
  background: none;
  border: none;
  width: 36px;
  height: 36px;
  font-size: 18px;
  cursor: pointer;
  color: var(--purple-deep);
  font-family: var(--font-sans);
  transition: background .15s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cart-qty__btn:hover { background: var(--purple-pale); }
.cart-qty__val {
  min-width: 32px;
  text-align: center;
  font-weight: 600;
  font-size: 15px;
  color: var(--text-dark);
}
.cart-item__remove {
  background: none;
  border: none;
  font-size: 13px;
  color: var(--text-light);
  cursor: pointer;
  font-family: var(--font-sans);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color .2s;
  padding: 0;
}
.cart-item__remove:hover { color: #c0392b; }

/* SUMMARY */
.cart-summary {
  background: var(--white);
  border-radius: 20px;
  padding: 32px;
  border: 1px solid rgba(167,139,204,0.2);
  position: sticky;
  top: 96px;
}
.cart-summary__title {
  font-family: var(--font-serif);
  font-size: 22px;
  color: var(--text-dark);
  margin-bottom: 24px;
}
.cart-summary__rows {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 16px;
}
.cart-summary__row {
  display: flex;
  justify-content: space-between;
  font-size: 15px;
  color: var(--text-mid);
}
.cart-summary__row--shipping { font-size: 14px; }
.cart-free-badge {
  background: #E8F5E9;
  color: #2E7D32;
  font-size: 12px;
  font-weight: 700;
  padding: 2px 10px;
  border-radius: 100px;
}
.cart-shipping-note {
  background: var(--purple-pale);
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 13px;
  color: var(--purple-mid);
  font-weight: 500;
  margin-bottom: 20px;
  text-align: center;
}
.cart-shipping-note--unlocked {
  background: #E8F5E9;
  color: #2E7D32;
}
.cart-summary__total {
  display: flex;
  justify-content: space-between;
  font-size: 18px;
  font-weight: 700;
  color: var(--text-dark);
  padding-top: 16px;
  border-top: 1px solid rgba(167,139,204,0.2);
  margin-bottom: 24px;
}
.cart-checkout-btn {
  width: 100%;
  text-align: center;
  margin-bottom: 16px;
}
.cart-trust {
  display: flex;
  justify-content: center;
  gap: 20px;
  font-size: 12px;
  color: var(--text-light);
  margin-bottom: 20px;
}
.cart-continue {
  display: block;
  text-align: center;
  font-size: 13px;
  color: var(--text-light);
  font-weight: 500;
  transition: color .2s;
}
.cart-continue:hover { color: var(--purple-mid); }

/* EMPTY */
.cart-empty {
  text-align: center;
  padding: 80px 24px;
  max-width: 480px;
  margin: 0 auto;
}
.cart-empty__icon { font-size: 72px; margin-bottom: 24px; }
.cart-empty__title {
  font-family: var(--font-serif);
  font-size: 36px;
  color: var(--text-dark);
  margin-bottom: 16px;
}
.cart-empty__sub {
  font-size: 16px;
  color: var(--text-mid);
  line-height: 1.7;
  margin-bottom: 32px;
}

/* RESPONSIVE */
@media(max-width: 860px) {
  .cart-page__grid {
    grid-template-columns: 1fr;
  }
  .cart-summary {
    position: static;
  }
}
</style>

<script>
(function() {
  function updateCart(key, qty) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(r => r.json())
    .then(function() { window.location.reload(); });
  }

  document.querySelectorAll('.cart-qty__btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      updateCart(this.dataset.key, parseInt(this.dataset.qty));
    });
  });

  document.querySelectorAll('.cart-item__remove').forEach(function(btn) {
    btn.addEventListener('click', function() {
      updateCart(this.dataset.key, 0);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Cart Page",
  "settings": [],
  "presets": [{ "name": "Cart Page" }]
}
{% endschema %}
