<section class="problem-section">
  <div class="container text-center">
    <span class="section-label">The Problem</span>
    <h2 class="section-title">You're not <em>actually</em> recovering.</h2>
    <p class="section-sub centered">Most people train hard but neglect the one thing their muscles need most. Your body can only produce about 1g of creatine per day — the rest has to come from somewhere.</p>
  </div>
  <div class="problem-grid">
    <div class="problem-stat">
      <div class="stat-number">70%</div>
      <div class="stat-label">of active people don't<br>get enough creatine from food</div>
    </div>
    <div class="problem-stat">
      <div class="stat-number">20%</div>
      <div class="stat-label">average increase in<br>high-intensity performance</div>
    </div>
    <div class="problem-stat">
      <div class="stat-number">1 in 3</div>
      <div class="stat-label">gym-goers are training<br>with depleted creatine stores</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Problem Section",
  "settings": [],
  "presets": [{ "name": "Problem Section" }]
}
{% endschema %}
