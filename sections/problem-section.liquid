<section class="problem-section">
  <div class="container text-center">
    <span class="section-label">The Problem</span>
    <h2 class="section-title">You're not <em>actually</em> sleeping.</h2>
    <p class="section-sub centered">Most people think they're getting 7–8 hours of sleep. What they're actually getting is 7–8 hours in bed. There's a difference.</p>
  </div>
  <div class="problem-grid">
    <div class="problem-stat">
      <div class="stat-number">62%</div>
      <div class="stat-label">of adults worldwide<br>report sleeping poorly</div>
    </div>
    <div class="problem-stat">
      <div class="stat-number">27m</div>
      <div class="stat-label">average time it takes<br>to fall asleep each night</div>
    </div>
    <div class="problem-stat">
      <div class="stat-number">1 in 3</div>
      <div class="stat-label">adults are chronically<br>sleep deprived</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Problem Section",
  "settings": [],
  "presets": [{ "name": "Problem Section" }]
}
{% endschema %}
