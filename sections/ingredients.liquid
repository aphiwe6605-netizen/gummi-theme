<section class="ingredients-section" id="ingredients">
  <div class="container">
    <span class="section-label">The Formula</span>
    <h2 class="section-title">Three ingredients.<br><em>Built to perform.</em></h2>
    <p class="section-sub">We didn't throw everything at the wall. We studied what your body actually needs to perform — and built the formula around that.</p>

    <div class="ingredients-grid">
      {%- for i in (1..3) -%}
        {%- assign icon_key = 'icon_' | append: i -%}
        {%- assign name_key = 'name_' | append: i -%}
        {%- assign role_key = 'role_' | append: i -%}
        {%- assign desc_key = 'desc_' | append: i -%}
        <div class="ingredient-card">
          <div class="ingredient-icon">{{ section.settings[icon_key] }}</div>
          <h3 class="ingredient-name">{{ section.settings[name_key] }}</h3>
          <p class="ingredient-role">{{ section.settings[role_key] }}</p>
          <p class="ingredient-desc">{{ section.settings[desc_key] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients",
  "settings": [
    { "type": "text", "id": "icon_1", "label": "Icon 1", "default": "💪" },
    { "type": "text", "id": "name_1", "label": "Name 1", "default": "Creatine Monohydrate" },
    { "type": "text", "id": "role_1", "label": "Role 1", "default": "The Powerhouse" },
    { "type": "textarea", "id": "desc_1", "label": "Description 1", "default": "Clinically dosed at 3g per serving — the most researched supplement in sports science. Creatine fuels your muscles, sharpens your focus, and helps you push harder every single session." },
    { "type": "text", "id": "icon_2", "label": "Icon 2", "default": "⚡" },
    { "type": "text", "id": "name_2", "label": "Name 2", "default": "Vitamin B6" },
    { "type": "text", "id": "role_2", "label": "Role 2", "default": "The Catalyst" },
    { "type": "textarea", "id": "desc_2", "label": "Description 2", "default": "Drives energy metabolism so your body actually uses what you put in. B6 supports protein synthesis, reduces fatigue, and keeps your nervous system firing at full capacity." },
    { "type": "text", "id": "icon_3", "label": "Icon 3", "default": "💧" },
    { "type": "text", "id": "name_3", "label": "Name 3", "default": "Electrolytes" },
    { "type": "text", "id": "role_3", "label": "Role 3", "default": "The Balance" },
    { "type": "textarea", "id": "desc_3", "label": "Description 3", "default": "Hydration isn't just water. Electrolytes regulate muscle contractions, prevent cramping, and keep your performance from fading. The part most creatine supplements forget — we didn't." }
  ],
  "presets": [{ "name": "Ingredients" }]
}
{% endschema %}
