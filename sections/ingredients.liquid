<section class="ingredients-section" id="ingredients">
  <div class="container">
    <span class="section-label">The Formula</span>
    <h2 class="section-title">Three ingredients.<br><em>One perfect night.</em></h2>
    <p class="section-sub">We didn't throw everything at the wall. We studied what your body actually needs at bedtime — and built the formula around that.</p>

    <div class="ingredients-grid">
      {%- for i in (1..3) -%}
        {%- assign icon_key = 'icon_' | append: i -%}
        {%- assign name_key = 'name_' | append: i -%}
        {%- assign role_key = 'role_' | append: i -%}
        {%- assign desc_key = 'desc_' | append: i -%}
        <div class="ingredient-card">
          <div class="ingredient-icon">{{ section.settings[icon_key] }}</div>
          <h3 class="ingredient-name">{{ section.settings[name_key] }}</h3>
          <p class="ingredient-role">{{ section.settings[role_key] }}</p>
          <p class="ingredient-desc">{{ section.settings[desc_key] }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients",
  "settings": [
    { "type": "text", "id": "icon_1", "label": "Icon 1", "default": "🌙" },
    { "type": "text", "id": "name_1", "label": "Name 1", "default": "Melatonin" },
    { "type": "text", "id": "role_1", "label": "Role 1", "default": "The Signal" },
    { "type": "textarea", "id": "desc_1", "label": "Description 1", "default": "Tells your brain it's time to wind down — naturally, not forcefully. Melatonin works with your body's rhythm, not against it. You ease into sleep. You're not knocked out." },
    { "type": "text", "id": "icon_2", "label": "Icon 2", "default": "🍃" },
    { "type": "text", "id": "name_2", "label": "Name 2", "default": "L-Theanine" },
    { "type": "text", "id": "role_2", "label": "Role 2", "default": "The Quiet" },
    { "type": "textarea", "id": "desc_2", "label": "Description 2", "default": "Found naturally in green tea, L-Theanine quiets the mental noise that keeps you awake. The meetings you didn't nail. The thing you said in 2019. Gone. It calms without sedating." },
    { "type": "text", "id": "icon_3", "label": "Icon 3", "default": "🌸" },
    { "type": "text", "id": "name_3", "label": "Name 3", "default": "Passion Flower" },
    { "type": "text", "id": "role_3", "label": "Role 3", "default": "The Anchor" },
    { "type": "textarea", "id": "desc_3", "label": "Description 3", "default": "Used for centuries as a natural calming agent. Modern science now backs what traditional medicine always knew — passion flower keeps your nervous system settled through the night." }
  ],
  "presets": [{ "name": "Ingredients" }]
}
{% endschema %}
