<section class="subscribe-checkout">
  <div class="container">

    <a href="/products/gummi" class="subscribe-back">← Back to product</a>

    <div class="subscribe-checkout__grid">

      <!-- LEFT: Order Summary -->
      <div class="subscribe-checkout__left">
        <div class="subscribe-badge">Subscribe & Save 10%</div>
        <h1 class="subscribe-checkout__title">Monthly Gummi Delivery</h1>
        <p class="subscribe-checkout__sub">Better sleep, every month — delivered automatically.</p>

        <div class="subscribe-product-card">
          <div class="subscribe-product-card__icon">🌙</div>
          <div class="subscribe-product-card__info">
            <div class="subscribe-product-card__name">Gummi Sleep Gummies</div>
            <div class="subscribe-product-card__meta">60 gummies · 1 month supply · All-natural</div>
          </div>
          <div class="subscribe-product-card__price">
            <span class="subscribe-product-card__price-main">R450</span>
            <span class="subscribe-product-card__price-unit">/mo</span>
          </div>
        </div>

        <div class="subscribe-breakdown">
          <div class="subscribe-breakdown__row">
            <span>Regular price</span>
            <span class="subscribe-strikethrough">R500.00</span>
          </div>
          <div class="subscribe-breakdown__row subscribe-breakdown__row--savings">
            <span>Subscriber discount (10%)</span>
            <span>-R50.00</span>
          </div>
          <div class="subscribe-breakdown__divider"></div>
          <div class="subscribe-breakdown__row subscribe-breakdown__row--total">
            <span>Charged today & monthly</span>
            <span>R450.00</span>
          </div>
        </div>

        <div class="subscribe-perks">
          <div class="subscribe-perk">✓ Cancel anytime — no lock-in</div>
          <div class="subscribe-perk">✓ Free delivery on every order</div>
          <div class="subscribe-perk">✓ 10% off every month</div>
          <div class="subscribe-perk">✓ Secure billing via PayFast 🔒</div>
        </div>
      </div>

      <!-- RIGHT: Customer Details + PayFast -->
      <div class="subscribe-checkout__right">
        <h2 class="subscribe-checkout__form-title">Your details</h2>
        <p class="subscribe-checkout__form-sub">We'll redirect you to PayFast to complete payment securely.</p>

        <form id="subscribe-form" class="subscribe-form" novalidate>
          <div class="subscribe-form__row">
            <div class="subscribe-form__group">
              <label for="sf-first">First name</label>
              <input type="text" id="sf-first" placeholder="Jane" required autocomplete="given-name">
            </div>
            <div class="subscribe-form__group">
              <label for="sf-last">Last name</label>
              <input type="text" id="sf-last" placeholder="Doe" required autocomplete="family-name">
            </div>
          </div>

          <div class="subscribe-form__group">
            <label for="sf-email">Email address</label>
            <input type="email" id="sf-email" placeholder="jane@example.com" required autocomplete="email">
            <span class="subscribe-form__hint">PayFast will send your receipt here</span>
          </div>

          <div id="subscribe-error" class="subscribe-error" style="display:none;"></div>

          <button type="submit" class="btn-primary subscribe-submit" id="subscribe-submit-btn">
            Subscribe & Pay R450 →
          </button>

          <p class="subscribe-cancel-note">You'll be charged R450 today and on the same date each month. Cancel anytime via PayFast.</p>

          <div class="subscribe-trust">
            <span>🔒 SSL Secured</span>
            <span>💳 PayFast Protected</span>
            <span>🇿🇦 SA Billing</span>
          </div>
        </form>

        <!-- Hidden PayFast subscription form — submitted by JS -->
        <form id="payfast-form" action="https://www.payfast.co.za/eng/process" method="post" style="display:none;">
          <input type="hidden" name="merchant_id" value="15727312">
          <input type="hidden" name="merchant_key" value="can3tiywcph5d">
          <input type="hidden" name="return_url" value="{{ shop.url }}/pages/thank-you">
          <input type="hidden" name="cancel_url" value="{{ shop.url }}/pages/subscribe">
          <input type="hidden" name="notify_url" value="{{ shop.url }}/">
          <input type="hidden" name="name_first" id="pf-first" value="">
          <input type="hidden" name="name_last" id="pf-last" value="">
          <input type="hidden" name="email_address" id="pf-email" value="">
          <input type="hidden" name="amount" value="450.00">
          <input type="hidden" name="item_name" value="Gummi Sleep Gummies Monthly Subscription">
          <input type="hidden" name="subscription_type" value="1">
          <input type="hidden" name="billing_date" id="pf-billing-date" value="">
          <input type="hidden" name="recurring_amount" value="450.00">
          <input type="hidden" name="frequency" value="3">
          <input type="hidden" name="cycles" value="0">
          <input type="hidden" name="signature" id="pf-signature" value="">
        </form>
      </div>

    </div>
  </div>
</section>

<style>
.subscribe-checkout {
  padding: 48px 24px 100px;
  min-height: 80vh;
  background: var(--cream);
}
.subscribe-back {
  display: inline-block;
  color: var(--text-light);
  font-size: 14px;
  margin-bottom: 36px;
  transition: color .2s;
  font-weight: 500;
}
.subscribe-back:hover { color: var(--purple-mid); }

.subscribe-checkout__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  max-width: 980px;
  margin: 0 auto;
  align-items: start;
}

/* LEFT */
.subscribe-badge {
  display: inline-block;
  background: var(--purple-deep);
  color: var(--white);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 100px;
  margin-bottom: 20px;
}
.subscribe-checkout__title {
  font-family: var(--font-serif);
  font-size: clamp(28px, 3.5vw, 40px);
  color: var(--text-dark);
  margin-bottom: 8px;
  line-height: 1.2;
}
.subscribe-checkout__sub {
  font-size: 16px;
  color: var(--text-mid);
  margin-bottom: 32px;
  line-height: 1.6;
}

.subscribe-product-card {
  display: flex;
  align-items: center;
  gap: 16px;
  background: var(--white);
  border-radius: 16px;
  padding: 20px;
  border: 1.5px solid rgba(167,139,204,0.25);
  margin-bottom: 20px;
}
.subscribe-product-card__icon { font-size: 36px; flex-shrink: 0; }
.subscribe-product-card__info { flex: 1; }
.subscribe-product-card__name {
  font-weight: 700;
  font-size: 16px;
  color: var(--text-dark);
  margin-bottom: 4px;
}
.subscribe-product-card__meta { font-size: 13px; color: var(--text-light); }
.subscribe-product-card__price { flex-shrink: 0; text-align: right; }
.subscribe-product-card__price-main {
  font-size: 26px;
  font-weight: 800;
  color: var(--purple-deep);
}
.subscribe-product-card__price-unit { font-size: 14px; color: var(--text-light); }

.subscribe-breakdown {
  background: var(--white);
  border-radius: 16px;
  padding: 20px 24px;
  border: 1.5px solid rgba(167,139,204,0.25);
  margin-bottom: 24px;
}
.subscribe-breakdown__row {
  display: flex;
  justify-content: space-between;
  font-size: 14px;
  color: var(--text-mid);
  padding: 6px 0;
}
.subscribe-breakdown__row--savings { color: #2e7d32; font-weight: 500; }
.subscribe-strikethrough { text-decoration: line-through; color: var(--text-light); }
.subscribe-breakdown__divider {
  height: 1px;
  background: rgba(167,139,204,0.2);
  margin: 8px 0;
}
.subscribe-breakdown__row--total {
  font-weight: 700;
  font-size: 16px;
  color: var(--text-dark);
  padding-top: 10px;
}

.subscribe-perks { display: flex; flex-direction: column; gap: 10px; }
.subscribe-perk { font-size: 14px; color: var(--text-mid); font-weight: 500; }

/* RIGHT */
.subscribe-checkout__right {
  background: var(--white);
  border-radius: 20px;
  padding: 36px;
  border: 1px solid rgba(167,139,204,0.2);
  position: sticky;
  top: 96px;
}
.subscribe-checkout__form-title {
  font-family: var(--font-serif);
  font-size: 24px;
  color: var(--text-dark);
  margin-bottom: 6px;
}
.subscribe-checkout__form-sub {
  font-size: 14px;
  color: var(--text-light);
  margin-bottom: 28px;
  line-height: 1.5;
}

.subscribe-form__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.subscribe-form__group {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 20px;
}
.subscribe-form__group label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-dark);
}
.subscribe-form__group input {
  padding: 12px 16px;
  border: 1.5px solid rgba(167,139,204,0.35);
  border-radius: 10px;
  font-size: 15px;
  font-family: var(--font-sans);
  color: var(--text-dark);
  background: var(--cream);
  transition: border-color .2s, background .2s;
  outline: none;
}
.subscribe-form__group input:focus {
  border-color: var(--purple-mid);
  background: var(--white);
}
.subscribe-form__group input::placeholder { color: var(--text-light); }
.subscribe-form__hint { font-size: 12px; color: var(--text-light); }

.subscribe-error {
  background: #fdecea;
  color: #c0392b;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 13px;
  margin-bottom: 16px;
  font-weight: 500;
}

.subscribe-submit {
  width: 100%;
  text-align: center;
  margin-bottom: 12px;
  font-size: 16px;
  padding: 16px;
}
.subscribe-submit:disabled { opacity: .7; cursor: not-allowed; }

.subscribe-cancel-note {
  font-size: 12px;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20px;
}
.subscribe-trust {
  display: flex;
  justify-content: center;
  gap: 16px;
  font-size: 12px;
  color: var(--text-light);
  flex-wrap: wrap;
}

@media(max-width: 760px) {
  .subscribe-checkout__grid {
    grid-template-columns: 1fr;
    gap: 32px;
  }
  .subscribe-checkout__right { position: static; padding: 28px 20px; }
  .subscribe-form__row { grid-template-columns: 1fr; }
}
</style>

<script>
(function () {
  /* Minimal MD5 — used to generate PayFast signature */
  function md5(s) {
    var hc = "0123456789abcdef";
    function rh(n) { var j, r = ""; for (j = 0; j <= 3; j++) r += hc.charAt((n >> (j * 8 + 4)) & 0xF) + hc.charAt((n >> (j * 8)) & 0xF); return r; }
    function ad(x, y) { var l = (x & 0xFFFF) + (y & 0xFFFF), m = (x >> 16) + (y >> 16) + (l >> 16); return (m << 16) | (l & 0xFFFF); }
    function rl(n, c) { return (n << c) | (n >>> (32 - c)); }
    function cm(q, a, b, x, s, t) { return ad(rl(ad(ad(a, q), ad(x, t)), s), b); }
    function ff(a, b, c, d, x, s, t) { return cm((b & c) | (~b & d), a, b, x, s, t); }
    function gg(a, b, c, d, x, s, t) { return cm((b & d) | (c & ~d), a, b, x, s, t); }
    function hh(a, b, c, d, x, s, t) { return cm(b ^ c ^ d, a, b, x, s, t); }
    function ii(a, b, c, d, x, s, t) { return cm(c ^ (b | ~d), a, b, x, s, t); }
    function sb(x) {
      var i, nb = ((x.length + 8) >> 6) + 1, bl = new Array(nb * 16);
      for (i = 0; i < nb * 16; i++) bl[i] = 0;
      for (i = 0; i < x.length; i++) bl[i >> 2] |= x.charCodeAt(i) << ((i % 4) * 8);
      bl[i >> 2] |= 0x80 << ((i % 4) * 8); bl[nb * 16 - 2] = x.length * 8; return bl;
    }
    var i, x = sb(s), a = 1732584193, b = -271733879, c = -1732584194, d = 271733878, oa, ob, oc, od;
    for (i = 0; i < x.length; i += 16) {
      oa = a; ob = b; oc = c; od = d;
      a = ff(a,b,c,d,x[i],7,-680876936);    d = ff(d,a,b,c,x[i+1],12,-389564586);   c = ff(c,d,a,b,x[i+2],17,606105819);     b = ff(b,c,d,a,x[i+3],22,-1044525330);
      a = ff(a,b,c,d,x[i+4],7,-176418897);  d = ff(d,a,b,c,x[i+5],12,1200080426);   c = ff(c,d,a,b,x[i+6],17,-1473231341);   b = ff(b,c,d,a,x[i+7],22,-45705983);
      a = ff(a,b,c,d,x[i+8],7,1770035416);  d = ff(d,a,b,c,x[i+9],12,-1958414417);  c = ff(c,d,a,b,x[i+10],17,-42063);       b = ff(b,c,d,a,x[i+11],22,-1990404162);
      a = ff(a,b,c,d,x[i+12],7,1804603682); d = ff(d,a,b,c,x[i+13],12,-40341101);   c = ff(c,d,a,b,x[i+14],17,-1502002290);  b = ff(b,c,d,a,x[i+15],22,1236535329);
      a = gg(a,b,c,d,x[i+1],5,-165796510);  d = gg(d,a,b,c,x[i+6],9,-1069501632);   c = gg(c,d,a,b,x[i+11],14,643717713);    b = gg(b,c,d,a,x[i],20,-373897302);
      a = gg(a,b,c,d,x[i+5],5,-701558691);  d = gg(d,a,b,c,x[i+10],9,38016083);     c = gg(c,d,a,b,x[i+15],14,-660478335);   b = gg(b,c,d,a,x[i+4],20,-405537848);
      a = gg(a,b,c,d,x[i+9],5,568446438);   d = gg(d,a,b,c,x[i+14],9,-1019803690);  c = gg(c,d,a,b,x[i+3],14,-187363961);    b = gg(b,c,d,a,x[i+8],20,1163531501);
      a = gg(a,b,c,d,x[i+13],5,-1444681467);d = gg(d,a,b,c,x[i+2],9,-51403784);     c = gg(c,d,a,b,x[i+7],14,1735328473);    b = gg(b,c,d,a,x[i+12],20,-1926607734);
      a = hh(a,b,c,d,x[i+5],4,-378558);     d = hh(d,a,b,c,x[i+8],11,-2022574463);  c = hh(c,d,a,b,x[i+11],16,1839030562);   b = hh(b,c,d,a,x[i+14],23,-35309556);
      a = hh(a,b,c,d,x[i+1],4,-1530992060); d = hh(d,a,b,c,x[i+4],11,1272893353);   c = hh(c,d,a,b,x[i+7],16,-155497632);    b = hh(b,c,d,a,x[i+10],23,-1094730640);
      a = hh(a,b,c,d,x[i+13],4,681279174);  d = hh(d,a,b,c,x[i],11,-358537222);     c = hh(c,d,a,b,x[i+3],16,-722521979);    b = hh(b,c,d,a,x[i+6],23,76029189);
      a = hh(a,b,c,d,x[i+9],4,-640364487);  d = hh(d,a,b,c,x[i+12],11,-421815835);  c = hh(c,d,a,b,x[i+15],16,530742520);    b = hh(b,c,d,a,x[i+2],23,-995338651);
      a = ii(a,b,c,d,x[i],6,-198630844);    d = ii(d,a,b,c,x[i+7],10,1126891415);   c = ii(c,d,a,b,x[i+14],15,-1416354905);  b = ii(b,c,d,a,x[i+5],21,-57434055);
      a = ii(a,b,c,d,x[i+12],6,1700485571); d = ii(d,a,b,c,x[i+3],10,-1894986606);  c = ii(c,d,a,b,x[i+10],15,-1051523);     b = ii(b,c,d,a,x[i+1],21,-2054922799);
      a = ii(a,b,c,d,x[i+8],6,1873313359);  d = ii(d,a,b,c,x[i+15],10,-30611744);   c = ii(c,d,a,b,x[i+6],15,-1560198380);   b = ii(b,c,d,a,x[i+13],21,1309151649);
      a = ii(a,b,c,d,x[i+4],6,-145523070);  d = ii(d,a,b,c,x[i+11],10,-1120210379); c = ii(c,d,a,b,x[i+2],15,718787259);     b = ii(b,c,d,a,x[i+9],21,-343485551);
      a = ad(a,oa); b = ad(b,ob); c = ad(c,oc); d = ad(d,od);
    }
    return rh(a) + rh(b) + rh(c) + rh(d);
  }

  /* URL encode the way PayFast expects (spaces as +) */
  function pfEnc(v) {
    return encodeURIComponent(String(v).trim()).replace(/%20/g, '+');
  }

  document.getElementById('subscribe-form').addEventListener('submit', function (e) {
    e.preventDefault();

    var first  = document.getElementById('sf-first').value.trim();
    var last   = document.getElementById('sf-last').value.trim();
    var email  = document.getElementById('sf-email').value.trim();
    var errEl  = document.getElementById('subscribe-error');
    var btn    = document.getElementById('subscribe-submit-btn');

    /* Validate */
    if (!first || !last || !email) {
      errEl.textContent = 'Please fill in all fields.';
      errEl.style.display = 'block';
      return;
    }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      errEl.textContent = 'Please enter a valid email address.';
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';

    /* Today's date as billing_date */
    var now = new Date();
    var billingDate = now.getFullYear() + '-' +
      String(now.getMonth() + 1).padStart(2, '0') + '-' +
      String(now.getDate()).padStart(2, '0');

    var shopUrl = '{{ shop.url }}';

    /* Build params IN ORDER — order matters for PayFast signature */
    var params = [
      ['merchant_id',      '15727312'],
      ['merchant_key',     'can3tiywcph5d'],
      ['return_url',       shopUrl + '/pages/thank-you'],
      ['cancel_url',       shopUrl + '/pages/subscribe'],
      ['notify_url',       shopUrl + '/'],
      ['name_first',       first],
      ['name_last',        last],
      ['email_address',    email],
      ['amount',           '450.00'],
      ['item_name',        'Gummi Sleep Gummies Monthly Subscription'],
      ['subscription_type','1'],
      ['billing_date',     billingDate],
      ['recurring_amount', '450.00'],
      ['frequency',        '3'],
      ['cycles',           '0']
    ];

    /* Build signature string & hash it */
    var sigStr = params.map(function (p) { return p[0] + '=' + pfEnc(p[1]); }).join('&');
    var signature = md5(sigStr);

    /* Populate the hidden PayFast form */
    document.getElementById('pf-first').value        = first;
    document.getElementById('pf-last').value         = last;
    document.getElementById('pf-email').value        = email;
    document.getElementById('pf-billing-date').value = billingDate;
    document.getElementById('pf-signature').value    = signature;

    btn.textContent = 'Redirecting to PayFast...';
    btn.disabled = true;

    document.getElementById('payfast-form').submit();
  });
})();
</script>

