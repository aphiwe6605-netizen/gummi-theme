        { "type": "faq_item", "settings": { "question": "How long until I see results?", "answer": "Most people notice a difference from the very first night. For best results, use consistently for at least 2 weeks to allow your sleep rhythm to fully reset." } },
        { "type": "faq_item", "settings": { "question": "Are they vegan and allergen-friendly?", "answer": "Yes — Gummi sleep gummies are vegan, gluten-free, and made with all-natural ingredients. No artificial colours, no nasties." } },
