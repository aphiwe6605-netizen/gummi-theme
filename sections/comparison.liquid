<style>
.comparison-section {
  padding: 80px 24px;
  background: var(--cream);
}

.comparison-table-wrap {
  margin-top: 56px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.comparison-table {
  width: 100%;
  max-width: 820px;
  margin: 0 auto;
  border-collapse: collapse;
  border-spacing: 0;
}

.comp-feature-col {
  width: 38%;
}

.comp-col {
  width: 20.7%;
  text-align: center;
}

.comp-col--gummi {
  background: rgba(59,31,107,0.04);
  border-radius: 16px 16px 0 0;
  position: relative;
}

.comp-header {
  padding: 20px 12px 16px;
}

.comp-header-logo {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-mid);
  margin-bottom: 4px;
}

.comp-header-logo--neutral {
  color: var(--text-light);
}

.comp-col--gummi .comp-header-logo {
  color: var(--purple-deep);
  font-size: 18px;
  font-family: var(--font-serif);
}

.comp-header-sub {
  font-size: 11px;
  color: var(--text-light);
  font-weight: 500;
}

.comp-row {
  border-top: 1px solid rgba(167,139,204,0.12);
}

.comp-row:last-child {
  border-bottom: 1px solid rgba(167,139,204,0.12);
}

.comp-feature {
  font-size: 14px;
  color: var(--text-mid);
  padding: 14px 0;
  text-align: left;
  font-weight: 500;
}

.comp-val {
  text-align: center;
  padding: 14px 12px;
  vertical-align: middle;
}

.comp-val--gummi {
  background: rgba(59,31,107,0.04);
}

.comp-yes {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #E8F5E9;
  color: #2E7D32;
  font-size: 13px;
  font-weight: 700;
}

.comp-no {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #FFEBEE;
  color: #C62828;
  font-size: 13px;
  font-weight: 700;
}

.comp-partial {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #FFF8E1;
  color: #E65100;
  font-size: 14px;
  font-weight: 700;
}

.comp-legend {
  display: flex;
  gap: 24px;
  justify-content: center;
  margin-top: 24px;
}

.comp-legend-item {
  font-size: 12px;
  color: var(--text-light);
  display: flex;
  align-items: center;
  gap: 6px;
}

@media(max-width: 600px) {
  .comparison-table { font-size: 13px; }
  .comp-feature { font-size: 12px; padding: 12px 0; }
  .comp-val { padding: 12px 6px; }
  .comp-yes, .comp-no, .comp-partial { width: 22px; height: 22px; font-size: 11px; }
  .comp-col--gummi .comp-header-logo { font-size: 15px; }
}
</style>

{% schema %}
{
  "name": "Comparison Table",
  "settings": [],
  "presets": [{ "name": "Comparison Table" }]
}
{% endschema %}
