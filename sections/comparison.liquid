                <div class="comp-header-logo comp-header-logo--neutral">Capsule</div>
                <div class="comp-header-sub">Creatine Capsule</div>
              </div>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr class="comp-row">
            <td class="comp-feature">Clinically dosed creatine</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">No chalky taste or texture</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-yes">✓</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">No mixing or shaker needed</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-yes">✓</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Easy to take on the go</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Actually enjoyable to take</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Builds consistency</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Vegan &amp; gluten-free</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">No bloating or GI issues</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-partial">~</span></td>
            <td class="comp-val"><span class="comp-yes">✓</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Includes electrolytes + B6</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
          </tr>
          <tr class="comp-row">
            <td class="comp-feature">Money-back guarantee</td>
            <td class="comp-val comp-val--gummi"><span class="comp-yes">✓</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
            <td class="comp-val"><span class="comp-no">✗</span></td>
