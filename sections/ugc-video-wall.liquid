<section class="ugc-section">
  <div class="container text-center">
    <span class="section-label">{{ section.settings.label | default: 'Trending on Social' }}</span>
    <h2 class="section-title">{{ section.settings.heading | default: 'Real customers, <em>real results</em>' }}</h2>
    <p class="section-sub centered">{{ section.settings.subheading | default: 'Going viral on TikTok &amp; Instagram — watch why South Africans are switching to Gummi.' }}</p>

    <div class="ugc-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
        {%- if block.type == 'video' -%}
        <div class="ugc-card" {{ block.shopify_attributes }}>
          <div class="ugc-media">
            {%- if block.settings.video_file != blank -%}
            <video
              playsinline muted loop controls
              style="width:100%;height:100%;object-fit:cover;border-radius:14px;"
              {%- if block.settings.thumbnail -%}poster="{{ block.settings.thumbnail | image_url: width: 400 }}"{%- endif -%}
            >
              {%- for source in block.settings.video_file.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
            {%- elsif block.settings.thumbnail -%}
            <div class="ugc-thumb-wrap">
              <img src="{{ block.settings.thumbnail | image_url: width: 400 }}" alt="Customer video" style="width:100%;height:100%;object-fit:cover;border-radius:14px;">
              <div class="ugc-play-btn" aria-label="Play video">&#9654;</div>
            </div>
            {%- else -%}
            <div class="ugc-placeholder">
              <div class="ugc-play-btn">&#9654;</div>
              <p style="color:rgba(255,255,255,0.6);font-size:12px;margin-top:12px;">Add video in theme editor</p>
            </div>
            {%- endif -%}
          </div>
          <div class="ugc-meta">
            <span class="ugc-platform-badge ugc-platform-{{ block.settings.platform | downcase }}">
              {{ block.settings.platform | default: 'TikTok' }}
            </span>
            {%- if block.settings.caption != blank -%}
            <p class="ugc-caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        </div>
        {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
        <div class="ugc-card">
          <div class="ugc-media ugc-placeholder">
            <div class="ugc-play-btn">&#9654;</div>
            <p style="color:rgba(255,255,255,0.5);font-size:11px;margin-top:10px;">Add your TikTok video</p>
          </div>
          <div class="ugc-meta">
            <span class="ugc-platform-badge ugc-platform-tiktok">TikTok</span>
          </div>
        </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <div class="ugc-stats-row">
      <div class="ugc-stat">
        <div class="ugc-stat-num">4.9&#9733;</div>
        <div class="ugc-stat-label">Average Rating</div>
      </div>
      <div class="ugc-stat">
        <div class="ugc-stat-num">100+</div>
        <div class="ugc-stat-label">Happy Athletes</div>
      </div>
      <div class="ugc-stat">
        <div class="ugc-stat-num">Citrus</div>
        <div class="ugc-stat-label">Delicious Flavour</div>
      </div>
    </div>
  </div>
</section>

<style>
.ugc-section {
  padding: 80px 24px;
  background: var(--text-dark);
}
.ugc-section .section-label { color: var(--purple-light); }
.ugc-section .section-title { color: var(--white); }
.ugc-section .section-title em { color: var(--purple-light); }
.ugc-section .section-sub { color: rgba(255,255,255,0.6); }

.ugc-grid {
  display: flex;
  flex-direction: row;
  gap: 16px;
  margin-top: 48px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding-bottom: 8px;
  cursor: grab;
}
.ugc-grid::-webkit-scrollbar { display: none; }
.ugc-grid:active { cursor: grabbing; }
.ugc-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex-shrink: 0;
  width: 220px;
}
.ugc-media {
  aspect-ratio: 9/16;
  border-radius: 14px;
  overflow: hidden;
  background: #1a1a2e;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.ugc-thumb-wrap { width:100%; height:100%; position:relative; }
.ugc-placeholder {
  background: linear-gradient(135deg, #2d1458 0%, #1a0a35 100%);
  width: 100%; height: 100%;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.ugc-play-btn {
  width: 48px; height: 48px;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; color: white;
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}
.ugc-thumb-wrap .ugc-play-btn { position: absolute; }
.ugc-meta { display: flex; align-items: center; gap: 8px; }
.ugc-platform-badge {
  font-size: 10px; font-weight: 700;
  padding: 3px 10px; border-radius: 100px;
  letter-spacing: 0.06em;
}
.ugc-platform-tiktok { background: #010101; color: white; }
.ugc-platform-instagram { background: #E1306C; color: white; }
.ugc-caption { font-size: 12px; color: rgba(255,255,255,0.5); text-align: left; }

.ugc-stats-row {
  display: flex;
  justify-content: center;
  gap: 60px;
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid rgba(255,255,255,0.1);
}
.ugc-stat-num {
  font-family: var(--font-serif);
  font-size: 32px;
  color: var(--white);
  margin-bottom: 4px;
}
.ugc-stat-label {
  font-size: 13px;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
}

@media(max-width: 767px) {
  .ugc-card { width: 160px; }
  .ugc-stats-row { gap: 32px; }
  .ugc-stat-num { font-size: 24px; }
}
</style>

<script>
(function(){
  var el = document.querySelector('.ugc-grid');
  if(!el) return;
  var isDown = false, startX, scrollLeft;
  el.addEventListener('mousedown', function(e){
    isDown = true;
    startX = e.pageX - el.offsetLeft;
    scrollLeft = el.scrollLeft;
  });
  document.addEventListener('mouseup', function(){ isDown = false; });
  el.addEventListener('mousemove', function(e){
    if(!isDown) return;
    e.preventDefault();
    var x = e.pageX - el.offsetLeft;
    el.scrollLeft = scrollLeft - (x - startX);
  });
})();
</script>

{% schema %}
{
  "name": "UGC Video Wall",
  "settings": [
    { "type": "text", "id": "label", "label": "Section label", "default": "Trending on Social" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real customers, real results" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Going viral on TikTok & Instagram — watch why South Africans are switching to Gummi." }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        { "type": "video", "id": "video_file", "label": "Video" },
        { "type": "image_picker", "id": "thumbnail", "label": "Thumbnail / Poster image", "info": "Optional — shown before the video plays." },
        { "type": "select", "id": "platform", "label": "Platform", "options": [{"value":"TikTok","label":"TikTok"},{"value":"Instagram","label":"Instagram"}], "default": "TikTok" },
        { "type": "text", "id": "caption", "label": "Caption (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Video Wall",
      "blocks": [
        { "type": "video", "settings": { "platform": "TikTok" } },
        { "type": "video", "settings": { "platform": "TikTok" } },
        { "type": "video", "settings": { "platform": "TikTok" } },
        { "type": "video", "settings": { "platform": "Instagram" } },
        { "type": "video", "settings": { "platform": "TikTok" } },
        { "type": "video", "settings": { "platform": "Instagram" } }
      ]
    }
  ]
}
{% endschema %}
