<section class="hero" id="hero">
  <div class="hero-stars"></div>
  <div class="hero__content">
    <span class="hero__eyebrow">💪 South Africa's Creatine Gummy</span>
    <h1 class="hero__title">
      Train <em>with</em><br>benefits.
    </h1>
    <p class="hero__sub">
      Skip the powder. Skip the shaker. Two gummies give you the creatine your muscles need to recover, grow, and go harder next session. That's it.
    </p>
    <div class="hero__buttons">
      <a href="/products/gummi" class="btn-primary">Shop Now — R449</a>
      <a href="#how" class="btn-secondary">How It Works</a>
    </div>
    <div class="hero__badges">
      <div class="hero__badge-item"><span>🌿</span> All-Natural</div>
      <div class="hero__badge-item"><span>⚡</span> 5g Creatine</div>
      <div class="hero__badge-item"><span>⭐</span> Wild Berry Flavour</div>
      <div class="hero__badge-item"><span>🇿🇦</span> Made for SA</div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "price", "label": "Product Price", "default": "449" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Sleep with benefits." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Two gummies. Thirty minutes. That's it." }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
