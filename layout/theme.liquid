<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: shop.description | default: 'Gummi — All-natural sleep gummies. Melatonin + L-Theanine + Passion Flower. Sleep with benefits.' }}">

  <title>{{ page_title | default: shop.name }}</title>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
</head>
<body>

  {%- if settings.announcement_text != blank -%}
  <div class="announcement-bar">
    {{ settings.announcement_text }}
  </div>
  {%- endif -%}

  <nav class="site-nav" role="navigation" aria-label="Main navigation">
    <span class="nav-star nav-star--1" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 2C20 2 22 14 28 20C34 26 38 28 38 28C38 28 26 30 20 36C14 42 12 38 12 38C12 38 14 26 8 20C2 14 2 12 2 12C2 12 14 10 20 2Z" fill="#C47200" opacity="0.55"/></svg>
    </span>
    <span class="nav-star nav-star--2" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 2C20 2 22 14 28 20C34 26 38 28 38 28C38 28 26 30 20 36C14 42 12 38 12 38C12 38 14 26 8 20C2 14 2 12 2 12C2 12 14 10 20 2Z" fill="#C47200" opacity="0.4"/></svg>
    </span>
    <span class="nav-star nav-star--3" aria-hidden="true">
      <svg width="18" height="18" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20 2C20 2 22 14 28 20C34 26 38 28 38 28C38 28 26 30 20 36C14 42 12 38 12 38C12 38 14 26 8 20C2 14 2 12 2 12C2 12 14 10 20 2Z" fill="#F09020" opacity="0.6"/></svg>
    </span>

    <a href="{{ routes.root_url }}" class="site-nav__logo">gummi</a>

    <ul class="site-nav__links">
      <li><a href="#product">Shop</a></li>
      <li><a href="#ingredients">Ingredients</a></li>
      <li><a href="#how">How It Works</a></li>
      <li><a href="#reviews">Reviews</a></li>
      <li><a href="#faq">FAQ</a></li>
    </ul>

    <div class="site-nav__actions">
      <a href="{{ routes.cart_url }}" class="nav-cart-icon" aria-label="Cart">
        🛒
        {%- if cart.item_count > 0 -%}
        <span class="cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </nav>

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {%- render 'footer' -%}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
